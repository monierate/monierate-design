        "$type": "color",
        "$value": "#000000",
        "$description": "Ink Black \u2014 headings and body"
      },
      "secondary": {
        "$type": "color",
        "$value": "#737373",
        "$description": "Slate Gray \u2014 supporting copy, timestamps"
      },
      "tertiary": {
        "$type": "color",
        "$value": "#B3B0B0",
        "$description": "Silver Gray \u2014 metadata, placeholders, disabled"
