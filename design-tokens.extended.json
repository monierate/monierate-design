{
  "$description": "Monierate design tokens \u2014 extended set (W3C design tokens format). Derived from monierate.fig, 2026-07-12.",
  "color": {
    "brand": {
      "default": {
        "$type": "color",
        "$value": "#1F75FE",
        "$description": "Crayola Blue \u2014 buttons, links, active tabs, focus glow"
      },
      "deep": {
        "$type": "color",
        "$value": "#134698",
        "$description": "Royal Navy \u2014 gradient end, pressed states"
      },
      "tint": {
        "$type": "color",
        "$value": "#F2F7FF",
        "$description": "Ice Blue \u2014 brand-tinted panels and banners"
      }
    },
    "text": {
