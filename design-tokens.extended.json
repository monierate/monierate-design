  "gradient": {
    "brand": {
      "$type": "gradient",
      "$value": [
        {
          "color": "#1F75FE",
          "position": 0
        },
        {
          "color": "#134698",
          "position": 1
        }
      ],
      "$description": "Hero panels, feature cards, primary banners"
    },
    "bitcoin": {
      "$type": "gradient",
      "$value": [
        {
          "color": "#F9AA4B",
          "position": 0
        },
        {
          "color": "#F7931A",
          "position": 1
        }
      ],
      "$description": "Bitcoin product surfaces"
    }
  },
  "font": {
    "family": {
      "head": {
        "$type": "fontFamily",
        "$value": [
          "Onest",
          "sans-serif"
        ],
        "$description": "Headings h1\u2013h6 (600, -1% LS), buttons, tab pills, highlight-card figures"
      },
      "body": {
        "$type": "fontFamily",
        "$value": [
          "Instrument Sans",
          "sans-serif"
        ],
        "$description": "Default on body/html and a/button/input/p/span/div \u2014 all UI and copy"
      },
      "mono": {
        "$type": "fontFamily",
        "$value": [
          "JetBrains Mono",
          "monospace"
        ],
        "$description": "All numerals: ticker prices, % changes, buy/sell rate cells (700, 17px desktop)"
      }
    },
    "weight": {
      "regular": {
        "$type": "fontWeight",
        "$value": 400,
        "$description": "Body default, ticker numerals"
      },
      "medium": {
        "$type": "fontWeight",
        "$value": 500,
        "$description": "UI emphasis"
      },
      "semibold": {
        "$type": "fontWeight",
        "$value": 600,
        "$description": "Headings, buttons (Onest)"
      },
      "bold": {
        "$type": "fontWeight",
        "$value": 700,
        "$description": "Rate cells (JetBrains Mono)"
      }
